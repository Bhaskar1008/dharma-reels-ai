# Server
PORT=3001
NODE_ENV=development

# Paths (relative to backend cwd or absolute)
OUTPUT_DIR=./storage/output
ASSETS_DIR=./storage/assets

# Storage: local (S3 reserved — see storageService)
STORAGE_PROVIDER=local

# TTS: mock | openai
TTS_PROVIDER=mock

# OpenAI (optional; when TTS_PROVIDER=openai or IMAGE_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Images: mock | openai (DALL·E 3)
IMAGE_PROVIDER=mock
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1024x1792

# Background music (optional; absolute or relative path). Omit or invalid file = voice only.
# BGM_PATH=./storage/assets/ambient.mp3
BGM_VOICE_VOLUME=1.0
BGM_MUSIC_VOLUME=0.25

# Ken Burns + cross-fade (per scene)
TRANSITION_FADE_SEC=0.35
KEN_BURNS_ZOOM_STEP=0.0012

# Encoding (file size vs quality)
VIDEO_CRF=23
VIDEO_PRESET=medium
VIDEO_AUDIO_BITRATE=192k
# Max output length in seconds (narration + video trimmed to this)
VIDEO_MAX_DURATION_SEC=60

# Queue: set USE_QUEUE=true and run `npm run worker` in another terminal / process
USE_QUEUE=false
REDIS_URL=redis://127.0.0.1:6379
QUEUE_CONCURRENCY=2
JOB_ATTEMPTS=2

# FFmpeg: defaults assume `ffmpeg` / `ffprobe` on PATH. On Windows (WinGet), set full paths to .exe:
# FFMPEG_PATH=C:\...\ffmpeg-8.x-full_build\bin\ffmpeg.exe
# FFPROBE_PATH=C:\...\ffmpeg-8.x-full_build\bin\ffprobe.exe
